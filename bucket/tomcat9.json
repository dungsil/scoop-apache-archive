{
    "homepage": "https://tomcat.apache.org",
    "version": "9.0.115",
    "checkver": {
        "url": "https://www.apache.org/dist/tomcat/tomcat-9/?C=M;O=D",
        "re": "v(?<version>[\\d.]+)"
    },
    "autoupdate": {
        "extract_dir": "apache-tomcat-$version",
        "architecture": {
            "32bit": {
                "url": "https://www.apache.org/dist/tomcat/tomcat-9/v$version/bin/apache-tomcat-$version-windows-x86.zip"
            },
            "64bit": {
                "url": "https://www.apache.org/dist/tomcat/tomcat-9/v$version/bin/apache-tomcat-$version-windows-x64.zip"
            }
        },
        "hash": {
            "url": "$url.sha512"
        }
    },
    "extract_dir": "apache-tomcat-9.0.115",
    "bin": "bin\\catalina.bat",
    "env_set": {
        "CATALINA_HOME": "$dir",
        "CATALINA_BASE": "$dir"
    },
    "suggest": {
        "JRE": "java/openjdk"
    },
    "architecture": {
        "64bit": {
            "url": "https://www.apache.org/dist/tomcat/tomcat-9/v9.0.115/bin/apache-tomcat-9.0.115-windows-x64.zip",
            "hash": "sha512:77e79950cc7fd1b00888fb351e542ec8235c071e5a021b980b5dabc3023a23bdee42beccaedf529c530c8ec85bab13d83662b8df22ac3dc596f295526375f5d5"
        },
        "32bit": {
            "url": "https://www.apache.org/dist/tomcat/tomcat-9/v9.0.115/bin/apache-tomcat-9.0.115-windows-x86.zip",
            "hash": "sha512:df4a18aca59f0c0341ac2cae867814bc495da31413e7d298a98e620d8745ac91cc9900dd2a473ba9ef90d08c0485d1a5af9ba69b683ad1e8605a4d8648c59bd8"
        }
    }
}
